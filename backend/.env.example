# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=copilot-files

# Azure Entra ID (set auth_enabled=true to enforce)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AUTH_ENABLED=false

# Workspace directory (where agents/skills are installed)
WORKSPACE_DIR=/workspace
AGENTS_DIR=.github/agents
SKILLS_DIR=.github/skills

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]
